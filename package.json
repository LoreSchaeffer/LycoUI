{
  "name": "lyco-ui-workspace",
  "private": true,
  "engines": {
    "node": ">=25.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:core": "npm run dev -w lyco-ui",
    "dev:docs": "npm run dev -w lyco-ui-docs",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true
  }
}
